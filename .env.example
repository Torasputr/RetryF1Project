# Copy to .env in the repo root for local notebooks and scripts.
# Used by src/openf1_de/fetch_bronze_*.py via python-dotenv load_dotenv().

PROJECT=trial-f1
LOCATION=asia-southeast2
BASE_URL=https://api.openf1.org/v1

# Bucket name only (no gs://). MEDAL_PUSH is the path prefix inside the bucket.
GCS_BUCKET=complete-f1
GCS_MEDAL_PUSH=bronze

YEAR=2026

# GCP auth for local runs: set GOOGLE_APPLICATION_CREDENTIALS to your service account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=secrets/gcp-sa.json
