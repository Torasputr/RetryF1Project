# Copy to airflow/.env and fill in values.
# Used by docker-compose.yaml (env_file: ${ENV_FILE_PATH:-.env})

# --- Airflow ---
# On Windows, 50000 is fine. On Linux, match your host UID to avoid permission issues.
AIRFLOW_UID=50000
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- GCP / BigQuery ---
PROJECT=trial-f1
LOCATION=asia-southeast2
BQ_RAW_DATASET=openf1_raw
DATASET=openf1_marts

# --- GCS ---
# Bucket name only (no gs://). MEDAL_* are path prefixes inside the bucket.
GCS_BUCKET=complete-f1
GCS_MEDAL_PUSH=bronze
GCS_MEDAL_FETCH=bronze
GCS_PUSH_BUCKET=data-mart-f1

# --- OpenF1 API & pipeline ---
BASE_URL=https://api.openf1.org/v1
# YEAR: season to fetch from the API on each ingest run.
# LOAD_YEARS: all years loaded from GCS into BigQuery for mart_schedule.
YEAR=2026
LOAD_YEARS=2025,2026
